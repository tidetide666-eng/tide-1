PORT=3000

# LLM provider (OpenAI-compatible)
# Free option suggestion: OpenRouter key + free model
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=openrouter/auto
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=mini-agent-scaffold

# Public API key for external callers
PUBLIC_API_KEY=change_this_public_api_key

ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
SESSION_SECRET=please_change_this_session_secret
